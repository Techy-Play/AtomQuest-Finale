# ═══════════════════════════════════════════════════════════════
#  ConnectDesk — Environment Variables
#  Copy this file to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────────────
# PostgreSQL connection string
# Local:  postgresql://postgres:password@localhost:5432/connectdesk
# Hosted: get from Neon (neon.tech) or Supabase (supabase.com)
DATABASE_URL="postgresql://user:password@localhost:5432/connectdesk"

# ── Authentication ──────────────────────────────────────────────
# Secret key for JWT token signing — use a long random string
JWT_SECRET="change-this-to-a-long-random-secret-key-min-32-chars"

# ── Cloudinary (file & recording storage) ──────────────────────
# Sign up free at: https://cloudinary.com
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ── Email / SMTP ────────────────────────────────────────────────
# For Gmail: enable 2FA → Settings → App Passwords → generate one
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@gmail.com"
SMTP_PASS="your_16_char_app_password"

# ── mediasoup SFU Networking ────────────────────────────────────
# Your machine's LAN IP address (the WiFi/Ethernet IP, NOT 127.0.0.1)
# Find it with:
#   Windows:  ipconfig | findstr "IPv4"
#   Linux:    ip addr show | grep "inet "
#   macOS:    ifconfig | grep "inet "
# Required for mobile devices to reach the SFU over WiFi.
MEDIASOUP_ANNOUNCED_IP="192.168.1.X"

# ── Ports (optional — defaults shown) ──────────────────────────
# SOCKET_PORT=3001
# PORT=3000

# ── App URL (optional) ──────────────────────────────────────────
# Only needed if deploying to a custom domain / behind a reverse proxy.
# Leave commented out for local use.
# NEXT_PUBLIC_APP_URL="https://your-domain.com"

# ── Socket URL override (optional) ─────────────────────────────
# Only set this if the SFU runs on a different host than the web app.
# Leave commented out for local use.
# NEXT_PUBLIC_SOCKET_URL="http://192.168.1.X:3001"
