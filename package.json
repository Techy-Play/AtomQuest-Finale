{
  "name": "video-support-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0 --turbopack",
    "dev:server": "npx tsx server.ts",
    "dev:all": "concurrently -k -n \"NEXT,SFU\" -c \"cyan,magenta\" \"next dev -H 0.0.0.0 --turbopack\" \"npx tsx server.ts\"",
    "build": "next build",
    "start": "node server.js",
    "lint": "eslint",
    "seed": "npx tsx prisma/seed.ts",
    "db:push": "npx prisma db push",
    "db:migrate": "npx prisma migrate dev"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/adapter-pg-worker": "^6.9.0",
    "@prisma/client": "^7.8.0",
    "@prisma/pg-worker": "^6.9.0",
    "@types/nodemailer": "^8.0.1",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "cookie": "^1.1.1",
    "dotenv": "^17.4.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.18.0",
    "mediasoup": "^3.20.5",
    "mediasoup-client": "^3.20.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.11",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.11.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie": "^0.6.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "concurrently": "^10.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
